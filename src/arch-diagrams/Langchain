graph TD
    subgraph "INPUT PROCESSING"
        direction LR
        UserInput[User Input / Messages] --> PromptTemplate[Prompt Templates];
        PromptTemplate -- Formatted Prompt --> CoreModel{Core Model};
        ExampleSelector[Example Selector: Informs the model with context] -- In-context Examples --> PromptTemplate;
    end

    subgraph "CORE MODEL LOGIC"
        direction TB
        CoreModel[Core Model]
        LanguageModels[Language Models: Use text input to generate text output] --> CoreModel;
        ChatModels[Chat Models: Respond like a human and handle messages from different roles such as Human, AI, System, Tool, etc.] --> CoreModel;
    end

    subgraph "OUTPUT PROCESSING"
        direction LR
        CoreModel -- Raw LLM Output --> OutputParsers[Output Parsers: Transform output into a suitable format];
        OutputParsers -- Structured Data --> FinalResult[Final Application Output];
    end

    %% Styling
    classDef input fill:#E1F5FE,stroke:#0277BD,stroke-width:2px;
    classDef core fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px;
    classDef output fill:#FFF3E0,stroke:#E65100,stroke-width:2px;

    class UserInput,PromptTemplate,ExampleSelector input;
    class LanguageModels,ChatModels core;
    class OutputParsers,FinalResult output;
